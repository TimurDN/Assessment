{
  "name": "qa-assessment-automation",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright test suite for the booking-flow assessment app.",
  "scripts": {
    "test": "playwright test --project=chromium-desktop",
    "test:all-browsers": "playwright test",
    "test:ui": "playwright test --project=chromium-desktop --ui",
    "test:headed": "playwright test --project=chromium-desktop --headed",
    "test:debug": "playwright test --project=chromium-desktop --debug",
    "test:api": "playwright test --grep @App-API --project=chromium-desktop",
    "test:e2e": "playwright test --grep @App-E2E --project=chromium-desktop",
    "test:regression": "playwright test --grep @App-regression --project=chromium-desktop",
    "test:ci": "playwright test --project=chromium-desktop --workers=1",
    "app-test": "playwright test --project=chromium-desktop",
    "app-test:ui": "playwright test --project=chromium-desktop --ui",
    "app-test:headed": "playwright test --project=chromium-desktop --headed",
    "app-test:debug": "playwright test --project=chromium-desktop --debug",
    "app-api": "playwright test --grep @App-API --project=chromium-desktop",
    "app-e2e": "playwright test --grep @App-E2E --project=chromium-desktop",
    "app-regression": "playwright test --grep @App-regression --project=chromium-desktop",
    "app-all": "playwright test --project=chromium-desktop --grep \"@App-(API|E2E|regression)\"",
    "app-ci": "playwright test --project=chromium-desktop --workers=1",
    "report": "playwright show-report",
    "codegen": "playwright codegen http://localhost:3000",
    "install-browsers": "playwright install --with-deps"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.56.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "zod": "^3.25.76"
  }
}
